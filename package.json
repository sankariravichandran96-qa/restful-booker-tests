{
  "name": "restful-booker-tests",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test:api": "npx playwright test --config=playwright.api.config.ts",
    "test:ui": "npx playwright test --config=playwright.ui.config.ts",
    "test:ui:headed": "npx playwright test --config=playwright.ui.config.ts --headed",
    "test:unit": "jest --testPathPatterns=unit.spec",
    "test:api:allure": "npx rimraf allure-results allure-report && npm run test:api && npm run report:allure",
    "test:ui:allure": "npx rimraf allure-results allure-report && npm run test:ui && npm run report:allure",
    "report:html": "npx playwright show-report",
    "report:allure": "npx allure generate allure-results --clean -o allure-report && npx allure open allure-report",
    "clean": "npx rimraf allure-results allure-report playwright-report test-results"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.5",
    "@babel/preset-typescript": "^7.28.5",
    "@playwright/test": "^1.59.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.6.2",
    "allure-commandline": "^2.40.0",
    "allure-js-commons": "^3.7.2",
    "allure-playwright": "^3.7.2",
    "babel-jest": "^30.4.1",
    "jest": "^29.7.0",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  },
 "jest": {
  "testEnvironment": "node",
  "testMatch": ["**/*.unit.spec.ts"],
  "transform": {
    "^.+\\.(ts|tsx)$": "babel-jest"
  }
}
}
